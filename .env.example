# Drizzle
DATABASE_URL="postgres://user:password@host:port/db-name"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Flue
GROQ_API_KEY="your-groq-api-key"
# Comma-separated list of origins allowed to call the Flue server (CORS).
# In production, set to your app URL (e.g. https://flux-web.fly.dev)
ALLOWED_ORIGIN=""

# CSRF — comma-separated list of additional allowed origins for mutating requests
# (same-origin is always allowed). Leave empty for same-origin only.
# In production, set to your app URL (e.g. https://flux-web.fly.dev)
CSRF_ALLOWED_ORIGINS=""

# SvelteKit ORIGIN — used by adapter-node for CSRF protection.
# In production, set to your app URL (e.g. https://flux-web.fly.dev)
ORIGIN=""

# Public (exposed to browser — inlined at build time via $env/static/public)
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# In production, set to your Flue server URL (e.g. https://flux-flue.fly.dev)
PUBLIC_FLUE_URL="http://localhost:3583"
